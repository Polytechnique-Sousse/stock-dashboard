generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  password  String
  name      String?
  role      Role     @default(USER)
  createdAt DateTime @default(now())
}

model Product {
  id          Int             @id @default(autoincrement())
  name        String
  category    String
  price       Float
  stock       Int             @default(0)
  threshold   Int             @default(5)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  description String?
  inbounds    Inbound[]
  outbounds   Outbound[]
  supplierId Int
  supplier   Supplier @relation(fields: [supplierId], references: [id])
  movements   StockMovement[]
}

model Supplier {
  id        Int      @id @default(autoincrement())
  name      String
  phone     String?
  email     String?
  address   String?
  products  String? 
  createdAt DateTime @default(now())
  productsList Product[]
}


model Inbound {
  id        Int      @id @default(autoincrement())
  quantity  Int
  note      String?
  date      DateTime @default(now())
  productId Int
  createdAt DateTime @default(now())
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model Outbound {
  id        Int      @id @default(autoincrement())
  quantity  Int
  client    String
  amount    Float
  date      DateTime @default(now())
  productId Int
  createdAt DateTime @default(now())
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model StockMovement {
  id        Int      @id @default(autoincrement())
  type      String
  quantity  Int
  productId Int
  createdAt DateTime @default(now())
  product   Product  @relation(fields: [productId], references: [id])
}

model Settings {
  id          Int     @id @default(autoincrement())
  companyName String?
  currency    String  @default("TND")
  unit        String  @default("kg")
  lowStock    Boolean @default(false)
  emailNotif  Boolean @default(false)
}

enum Role {
  ADMIN
  USER
}

enum OutboundStatus {
  PENDING
  PROCESSING
  DELIVERED
  CANCELLED
}
