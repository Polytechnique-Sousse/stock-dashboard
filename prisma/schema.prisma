generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  password  String
  name      String?
  role      Role     @default(USER)
  createdAt DateTime @default(now())
}

enum Role {
  ADMIN
  USER
}

model Product {
  id        Int        @id @default(autoincrement())
  name      String
  category  String
  price     Float
  stock     Int        @default(0)
  threshold Int        @default(5)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  inbounds  Inbound[]
  outbounds Outbound[]
}

model Supplier {
  id        Int      @id @default(autoincrement())
  name      String
  phone     String
  email     String   @unique
  address   String
  products  String
  leadTime  Int      @default(7)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Inbound {
  id        Int      @id @default(autoincrement())
  quantity  Int
  note      String?
  date      DateTime @default(now())
  productId Int
  product   Product  @relation(fields: [productId], references: [id])
  createdAt DateTime @default(now())
}

model Outbound {
  id        Int            @id @default(autoincrement())
  quantity  Int
  client    String
  amount    Float
  status    OutboundStatus @default(PENDING)
  note      String?
  date      DateTime       @default(now())
  productId Int
  product   Product        @relation(fields: [productId], references: [id])
  createdAt DateTime       @default(now())
}

enum OutboundStatus {
  PENDING
  PROCESSING
  DELIVERED
  CANCELLED
}